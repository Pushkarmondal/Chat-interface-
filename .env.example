# Local dev (Postgres/Redis on localhost — e.g. docker compose up postgres redis -d)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/chat?schema=public"
REDIS_URL="redis://localhost:6379"

# Must be >= 32 characters. If you use `docker compose up` for the app, match
# JWT_SECRET in docker-compose.yml when running `bun run db:seed` on the host.
JWT_SECRET="change-me-in-production-use-long-random-secret"

PORT=8080
NODE_ENV=development

# Mock S3 base URL for presigned upload responses (no real AWS required)
MOCK_S3_BUCKET_BASE_URL="https://mock-cdn.example.com/uploads"
